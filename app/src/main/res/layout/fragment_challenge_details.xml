<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryDarkBackground"
    android:padding="16dp">

    <TextView
        android:id="@+id/title_challenge_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/challenge_details"
        android:textColor="@color/buttonColor"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_go_to_main"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_challenge_details">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_details_challenge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Challenge: Visit a park within 500 m"
                android:textColor="@color/fontColor"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="18sp"
                android:text="Reason:"
                android:textColor="@color/fontColor"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_details_reasons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                android:text="• nearby park detected\n• distance below 500 m\n• category not visited today"
                android:textColor="@color/secondaryFontColor" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:text="Place details:"
                android:textColor="@color/fontColor"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_details_place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"
                android:text="Name: Planty Park\nCategory: Park\nDistance: 430 m"
                android:textColor="@color/secondaryFontColor" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_go_to_main"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/buttonColor"
        android:textSize="18sp"
        android:text="Back to Home"
        android:textColor="@color/fontColor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>