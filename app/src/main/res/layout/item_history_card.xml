<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:backgroundTint="@color/secondaryDarkBackground"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_history_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[Completed] Target Name"
            android:textColor="@color/successColor"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_history_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category: Nature\nCompleted: 2026-05-20 14:35"
            android:textColor="@color/secondaryFontColor" />
    </LinearLayout>
</androidx.cardview.widget.CardView>